	<div class="bg"></div>

	<div class="container-div">
		<div class="title-div">
			<img class="logo-512" src="images/logo_text_1024_512.png" />
			<div class="d-flex justify-content-between align-items-center gap-5 mb-3">
				<p style="margin: 0;">@localizer["GamePhaseTitle"]</p>
				<a style="text-decoration: underline; font-size: 12px; cursor: pointer;" @onclick="ShowInstructionModal">@localizer["GameShowInstructionModal"]</a>
			</div>
		</div>
		<div class="game-content-grid">
			<div class="chat-div" id="chat-div">
				<div class="chat-spacer"></div>
				<p style="margin: 0;">@((MarkupString)MessageBoxContent)</p>
			</div>
			<div class="feedback-div">
				<p>@((MarkupString)GeneralInformationBoxContent)</p>
				@if(currentQuestion > 0)
				{
					<div style="display: flex; flex-direction: column;">
						<p style="align-self: center; font-weight: bold;">@(string.Format((string)localizer["GameScoreboardTitle"], currentQuestion)) @* @($"Scores of players at question #{currentQuestion}") *@</p>
						<Scoreboard @key=@scoreboardRefreshKey PersonalizedFor="@Username" RelativeForQuestion="@currentQuestion" Rows="5" ShowTopPlayer="true" ShowBottomPlayer="true"></Scoreboard>
					</div>
				}
			</div>
			<div class="input-div">
				<input autofocus="autofocus"
					@ref="InputRef"
					@bind="UserMessageInput"
					@bind:event="oninput"
					@onkeydown="HandleInputKeyDown"
					disabled="@inputDisabled" />

					@if (chatThinking)
					{
					<button type="button" class="halt-button" @onclick="StopResponseButtonClick">
						<img class="animate animate--fade-in" src="images/halt_button.png" />
					</button>
					}
			</div>
			<div class="score-div">
				<p>@scoreBoxContent</p>
			</div>
		</div>
		@if (UserInfoStorage.GetScore(Username) != 0)
		{
			<div class="finish-button-div">
				<button type="button" class="btn btn-light"
						@onclick="ShowQuitConfirmationModal">
					@localizer["GameFinishAsking"]
				</button>
			</div>
		}
	</div>
</body>

@code {
	private bool IsRtl => CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
}
