@page "/game"
@inject NavigationManager navigationManager;

@if (IsRtl)
{
	<style>
		p, input {
			direction: rtl !important;
			text-align: right !important;
		}

		button {
			direction: rtl !important;
		}

		quit-modal-button {
			flex-direction: row-reverse
		}
	</style>
}

<script src="js/site.js"></script>

<body>
	<Modal @ref="quitConfirmationModal" Title="@localizer["GameConfirmationModalTitle"]" Style="color: #050505;">
		<BodyTemplate>
			@* You won't be able to ask any more questions during the design phase.
			<br/>
			Are you sure that you want to proceed to the design phase? *@
			<p>@((MarkupString)(string)localizer["GameConfirmationModal"])</p>
		</BodyTemplate>
		<FooterTemplate>
			<div class="quit-modal-button">
				<Button Color="ButtonColor.Danger" @onclick="FinishGame">@localizer["GameConfirmationModalContinue"]</Button>
				<Button Color="ButtonColor.Secondary" @onclick="OnHideQuitConfirmationModalClick">@localizer["GameConfirmationModalCancel"]</Button>
			</div>
		</FooterTemplate>
	</Modal>

	<Modal @ref="instructionModal" Title="@localizer["GameInformationModalTitle"]" Style="color: #050505;">
		<BodyTemplate>
			@* Your mission is to design a reliable and sustainable energy system for a city on Mars.<br/>To achieve this, you will interact with Mark,
			an AI-powered agent who has the answers to all questions relevant to planning the energy system. Ask creative, analytical, and relevant questions,
			and Mark will provide the information you need. You will earn points based on the quality of your questions, with relevance multiplying your score.<br/><br/>
			Gather information by asking the agent as many questions as you like. After each question, you'll
			receive feedback and earn points based on the quality and relevance of your inquiry. During the question phase, a short summary
			of each question you ask will appear on the right side of the screen. When you are ready to plan the energy system,
			click "Finish Asking" to proceed to the next phase. *@

			<p>@((MarkupString)(string)localizer["GameInformationModal"])</p>
		</BodyTemplate>
		<FooterTemplate>
			<Button Color="ButtonColor.Secondary" @onclick="OnHideInstructionModalClick">@localizer["GameInformationModalClose"]</Button>
		</FooterTemplate>
	</Modal>

