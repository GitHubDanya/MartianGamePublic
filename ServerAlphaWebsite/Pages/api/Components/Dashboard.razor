    <AuthorizeView Roles="admin">
        <Authorized>
            <div class="dashboard-container">

                <div class="tab-menu" style="margin-bottom: 20px; display: flex;">
                    <button class="btn btn-primary" @onclick='() => CurrentTab = DashboardPage.Dashboard'>Dashboard</button>
                    <button class="btn btn-secondary" @onclick='() => CurrentTab = DashboardPage.DownloadData'>Download Data</button>
                    <button class="btn btn-danger" @onclick='() => CurrentTab = DashboardPage.DeleteData'>Delete Data</button>
                    <a href="/api/auth/logout">logout</a>
                </div>

                <div class="tab-content" style="padding: 10px; border: 1px solid #ccc;">
                    @if (CurrentTab == DashboardPage.Dashboard)
                    {
                    <DataDisplay />
                    }
                    else if (CurrentTab == DashboardPage.DownloadData)
                    {
                    <DataDownload />
                    }
                    else if (CurrentTab == DashboardPage.DeleteData)
                    {
                    <p>Not implemented</p>
                    }
                </div>

            </div>
        </Authorized>
        <NotAuthorized>
            <div style="padding: 20px; color: red;">
                <h3>Access Denied</h3>
                <p>You do not have permission to view the admin dashboard.</p>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</body>
