@using ServerStorage
@using Parsers
@using DB
@inject NavigationManager NavigationManager
@inject UserInfoStorage UserInfoStorage
@inject IStringLocalizer<Resource> localizer
@inherits GamePageBase

@if (IsRtl)
{
	<style>
			p {
			direction: rtl !important;

		}
	</style>
}

<style>
	p {
		margin: 0;
	}

	@(@"@keyframes slideInUp {
    from {
        transform: translateY(100vh);
    }

    to {
        transform: translateY(0);
    }
	}") 

	.anim {
		animation: slideInUp 1s ease-out;
		animation-fill-mode: both;
	}
</style>

<Modal @ref="answerModal" Title="Your solution" Style="color: #050505;">
		<BodyTemplate>
			<div style="display: flex; flex-direction: column; align-items: center; gap: 10px;
">
				@answer
				<img style="max-height: 300px;" src="@(imageurl)" />
			</div>
		</BodyTemplate>
		<FooterTemplate>
			<Button Color="ButtonColor.Secondary" @onclick="HideAnswerModal">Close</Button>
		</FooterTemplate>
	</Modal>

<div class="d-flex flex-column align-items-center justify-content-center"
     style="min-height: 100vh; width: 100vw;
            font-size: 18px; font-weight: bold; gap: 12px;
            background-image: url(images/finish_background.png);
            overflow-y: auto;">
	<div class="d-flex flex-column align-items-center justify-content-center anim"
	     style="background-color: rgb(36, 36, 36);
		        box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.3);
			    padding: 20px;
				border-radius: 5px;
				gap: 8px;
				overflow-y: auto;">
	    <p>@localizer["Finish2Thanks"]</p>
		<a style="text-decoration: underline; cursor: pointer; color: #4d64fa;" href="@($"https://technioniit.eu.qualtrics.com/jfe/form/SV_0d2PvdLPp4tTWui?PROLIFIC_PID={pid}")">@localizer["Finish2Proceed"]</a>
		<p>@localizer["Finish2PID"]</p>
		<p style="padding: 5px; background-color: rgb(20, 20, 20); border-radius: 5px;">@(string.IsNullOrEmpty(pid) ? "No PID was provided" : pid)</p>
		<a style="text-decoration: underline; font-size: 12px; cursor: pointer;" @onclick="ShowAnswerModal">@localizer["Finish2CheckSolution"]</a>
		<p class="mt-3"><b>@localizer["Finish2ScoreboardTitle"]</b></p>
		<Scoreboard Rows="5" PersonalizedFor="@CurrentUser.Username"></Scoreboard>
	</div>
</div>

@code {
	private BlazorBootstrap.Modal answerModal = default!;
	string imageurl = "/images/alien.png";
	string answer = string.Empty;
	string pid = string.Empty;

	private bool IsRtl => CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;

	protected override async Task OnInitializedAsync()
	{
		if (CurrentUser != null)
		{
			imageurl = CurrentUser.ResultImageURL;
			pid = CurrentUser.ProlificID;
		}

		StateHasChanged();
	}

	private void ShowAnswerModal()
	{
		DbCommunicationProvider db = new();
		answer = db.FetchUserAnswer(CurrentUser.Username);

		StateHasChanged();

		_ = answerModal.ShowAsync();
	}

	private void HideAnswerModal()
	{
		_ = answerModal.HideAsync();
	}
}
